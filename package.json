{
  "name": "@prosperity-solutions/mcp-server-screenshot",
  "version": "1.0.0",
  "description": "MCP server for native macOS screenshot capture — screen, window, and region capture via screencapture",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-server-screenshot": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "printf '#!/usr/bin/env node\\n' | cat - dist/index.js > dist/index.js.tmp && mv dist/index.js.tmp dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "test": "node --test test/smoke.test.mjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "screenshot",
    "screen-capture",
    "macos",
    "screencapture",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "author": "prosperity solutions AG",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prosperity-solutions/mcp-server-screenshot.git"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.5.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
